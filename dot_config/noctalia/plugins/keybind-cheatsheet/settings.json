      "title": "Applications",
      "binds": [
        {
          "keys": "Super + Space",
          "desc": "Run: qs -c noctalia-shell ipc call launcher toggle"
        },
        {
          "keys": "Super + T",
          "desc": "Run: ghostty"
        },
        {
          "keys": "Super + Alt + L",
          "desc": "Run: qs -c noctalia-shell ipc call lockScreen lock"
