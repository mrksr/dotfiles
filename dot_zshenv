export PATH=$HOME/.nix-profile/bin:$HOME/.pyenv/bin:$HOME/.bin:$HOME/.local/bin:$HOME/.cargo/bin:/usr/bin/vendor_perl:$PATH

export EDITOR=nvim
export BROWSER=zen-browser

# Ensure oh-my-zsh cache dir exists
if [[ -z "$ZSH_CACHE_DIR" ]]; then
    export ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh-mrksr"
    mkdir -p "$ZSH_CACHE_DIR"
fi

if [[ -e "$HOME/.1password/agent.sock" ]]; then
    export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
fi
